      ],
      "env": {
        "PLAYWRIGHT_BROWSER": "chromium",
        "PLAYWRIGHT_BROWSER_CHANNEL": "brave"
      }
    },
    "docker": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-server-docker"
      ],
      "env": {
        "DOCKER_PATH": "C:\\Program Files\\Docker\\Docker\\resources\\bin\\docker"
      }
    },
    "qdrant": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-qdrant-memory"
      ],
      "env": {
        "QDRANT_URL": "http://localhost:6333"
      }
    }
  }
