{
  "servers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "c:\\Users\\lenovo\\Desktop\\ShitFix\\BSByClaude-Dev"
      ]
    },
    "everything": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-everything"
      ]
    },
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ]
    },
    "puppeteer": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-puppeteer"
      ],
      "env": {
        "PUPPETEER_EXECUTABLE_PATH": "C:\\Program Files\\BraveSoftware\\Brave-Browser\\Application\\brave.exe"
      }
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp"
      ],
      "env": {
        "PLAYWRIGHT_BROWSER_CHANNEL": "brave",
        "PLAYWRIGHT_EXECUTABLE_PATH": "C:\\Program Files\\BraveSoftware\\Brave-Browser\\Application\\brave.exe"
      }
    },
    "docker": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-server-docker"
      ],
      "env": {
        "DOCKER_PATH": "C:\\Program Files\\Docker\\Docker\\resources\\bin\\docker"
      }
    },
    "qdrant": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-qdrant-memory"
      ],
      "env": {
        "QDRANT_URL": "http://localhost:6333"
      }
    },
    "minibrain-memory": {
      "command": "node",
      "args": [
        "c:\\Users\\lenovo\\Desktop\\MiniBrain2\\mcp-servers\\minibrain-memory\\dist\\index.js"
      ],
      "env": {
        "MINIBRAIN_API_URL": "http://localhost:5089"
