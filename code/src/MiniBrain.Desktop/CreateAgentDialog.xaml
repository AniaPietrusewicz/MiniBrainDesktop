<Window x:Class="MiniBrain.Desktop.CreateAgentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create New Agent" Height="500" Width="600"
        WindowStartupLocation="CenterOwner"
        Background="#FF1E1E1E"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#FF0078D4"/>
        <SolidColorBrush x:Key="SecondaryBrush" Color="#FF2D2D30"/>
        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="SubTextBrush" Color="#FFB0B0B0"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#FF3F3F46"/>
        
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF1B9AE4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource SecondaryBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <TextBlock Grid.Row="0" Text="🤖 Create New AI Agent" FontSize="20" FontWeight="Bold" 
                 Foreground="{StaticResource TextBrush}" Margin="0,0,0,20"/>
        
        <!-- Form -->
        <StackPanel Grid.Row="1">
            <StackPanel Margin="0,0,0,15">
                <TextBlock Text="Agent Name:" Foreground="{StaticResource TextBrush}" 
                         FontWeight="Medium" Margin="0,0,0,5"/>
                <TextBox x:Name="NameTextBox" Style="{StaticResource ModernTextBox}"/>
            </StackPanel>
            
            <StackPanel Margin="0,0,0,15">
                <TextBlock Text="Description (Optional):" Foreground="{StaticResource TextBrush}" 
                         FontWeight="Medium" Margin="0,0,0,5"/>
                <TextBox x:Name="DescriptionTextBox" Style="{StaticResource ModernTextBox}"/>
            </StackPanel>
            
            <StackPanel>
                <TextBlock Text="System Instructions:" Foreground="{StaticResource TextBrush}" 
                         FontWeight="Medium" Margin="0,0,0,5"/>
                <TextBox x:Name="InstructionsTextBox" Style="{StaticResource ModernTextBox}"
                       Height="200" TextWrapping="Wrap" AcceptsReturn="True"
                       VerticalScrollBarVisibility="Auto"
                       Text="You are a helpful AI assistant. You should be professional, knowledgeable, and always strive to provide accurate and useful information to users. When you don't know something, admit it honestly rather than guessing."/>
            </StackPanel>
        </StackPanel>
        
        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" 
                   Margin="0,20,0,0">
            <Button Content="Cancel" Width="100" Margin="0,0,10,0"
                  Background="{StaticResource SecondaryBrush}"
                  Style="{StaticResource ModernButton}"
                  Click="Cancel_Click"/>
            <Button Content="Create Agent" Width="120"
                  Style="{StaticResource ModernButton}"
                  Click="Create_Click"/>
        </StackPanel>
    </Grid>
</Window>
